{
  "manifest_version": 3,
  "name": "Zero-G Ghost",
  "version": "6.5.0",
  "description": "Extreme minimalist browser optimization. Native culling, occlusion detection, and zero-latency intersection monitoring.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Zero-G Ghost"
  },
  "chrome_url_overrides": {
    "newtab": "zero-g-ghost.html"
  },
  "permissions": [
    "browsingData"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
